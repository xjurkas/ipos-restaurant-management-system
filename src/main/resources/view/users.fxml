<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="dev.vavateam1.controller.UsersController"
            maxWidth="Infinity"
            styleClass="page-root">

    <center>
        <HBox spacing="20"
              alignment="TOP_LEFT"
              maxWidth="Infinity"
              fillHeight="true"
              styleClass="page-content">
            <children>

                <VBox spacing="0"
                      minWidth="360"
                      maxHeight="Infinity"
                      HBox.hgrow="ALWAYS"
                      styleClass="menu-outer-panel">
                    <children>
                        <VBox spacing="18"
                              maxHeight="Infinity"
                              VBox.vgrow="ALWAYS"
                              styleClass="menu-inner-panel">
                            <children>
                                <ScrollPane fitToWidth="true"
                                            hbarPolicy="NEVER"
                                            vbarPolicy="AS_NEEDED"
                                            VBox.vgrow="ALWAYS"
                                            styleClass="page-scroll">
                                    <content>
                                        <VBox fx:id="usersList" spacing="18" />
                                    </content>
                                </ScrollPane>
                                <HBox alignment="CENTER_RIGHT">
                                    <children>
                                        <Button text="%users.createUser"
                                                onAction="#onCreateUser"
                                            styleClass="green-action-button" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                                <ScrollPane fx:id="userFormPanel"
                                            fitToWidth="true"
                                            fitToHeight="true"
                                            hbarPolicy="NEVER"
                                            vbarPolicy="NEVER"
                                            pannable="false"
                                            prefWidth="360"
                                            minWidth="320"
                                            maxWidth="390"
                                            maxHeight="Infinity"
                                            visible="false"
                                            managed="false"
                                            styleClass="menu-form-panel">
                                    <content>
                                        <VBox spacing="18"
                                              fillWidth="true"
                                              styleClass="menu-form-content">

                                            <HBox alignment="CENTER_RIGHT">
                                                <children>
                                                    <Button text="✕"
                                                            onAction="#onCloseForm"
                                                            styleClass="form-close-button" />
                                                </children>
                                            </HBox>

                                            <Label fx:id="formTitle"
                                                   text="%users.createUser"
                                                   wrapText="true"
                                                   styleClass="menu-category-title" />

                                            <VBox spacing="8">
                                                <children>
                                                    <Label text="%common.name" styleClass="form-label" />
                                                    <TextField fx:id="nameField"
                                                               maxWidth="Infinity"
                                                               styleClass="form-input" />
                                                </children>
                                            </VBox>

                                            <VBox spacing="8">
                                                <children>
                                                    <Label text="%common.surname" styleClass="form-label" />
                                                    <TextField fx:id="surnameField"
                                                               maxWidth="Infinity"
                                                               styleClass="form-input" />
                                                </children>
                                            </VBox>

                                            <VBox spacing="8">
                                                <children>
                                                    <Label text="%common.email" styleClass="form-label" />
                                                    <TextField fx:id="emailField"
                                                               maxWidth="Infinity"
                                                               styleClass="form-input" />
                                                </children>
                                            </VBox>

                                            <VBox spacing="8">
                                                <children>
                                                    <Label text="%common.password" styleClass="form-label" />
                                                    <PasswordField fx:id="passwordField"
                                                                   maxWidth="Infinity"
                                                                   styleClass="form-input" />
                                                </children>
                                            </VBox>

                                            <VBox spacing="8">
                                                <children>
                                                    <Label text="%users.repeatPassword" styleClass="form-label" />
                                                    <PasswordField fx:id="repeatPasswordField"
                                                                   maxWidth="Infinity"
                                                                   styleClass="form-input" />
                                                </children>
                                            </VBox>

                                            <VBox spacing="10">
                                                <fx:define>
                                                    <ToggleGroup fx:id="roleToggleGroup" />
                                                </fx:define>

                                                <children>
                                                    <Label text="%common.role" styleClass="form-label" />
                                                    <HBox spacing="8" fillHeight="true">
                                                        <children>
                                                            <ToggleButton fx:id="waiterRoleButton"
                                                                          text="%role.waiter"
                                                                          maxWidth="Infinity"
                                                                          HBox.hgrow="ALWAYS"
                                                                          toggleGroup="$roleToggleGroup"
                                                                          styleClass="role-toggle-button" />
                                                            <ToggleButton fx:id="chefRoleButton"
                                                                          text="%role.chef"
                                                                          maxWidth="Infinity"
                                                                          HBox.hgrow="ALWAYS"
                                                                          toggleGroup="$roleToggleGroup"
                                                                          styleClass="role-toggle-button" />
                                                            <ToggleButton fx:id="managerRoleButton"
                                                                          text="%role.admin"
                                                                          maxWidth="Infinity"
                                                                          HBox.hgrow="ALWAYS"
                                                                          toggleGroup="$roleToggleGroup"
                                                                          styleClass="role-toggle-button" />
                                                        </children>
                                                    </HBox>
                                                </children>
                                            </VBox>

                                            <Region VBox.vgrow="ALWAYS" />

                                            <Label fx:id="formErrorLabel"
                                                   wrapText="true"
                                                   styleClass="form-error-label"
                                                   visible="false"
                                                   managed="false" />

                                            <HBox alignment="CENTER_RIGHT" spacing="12">
                                                <children>
                                                    <Region HBox.hgrow="ALWAYS" />
                                                    <Button fx:id="deleteUserButton"
                                                        text="%common.delete"
                                                        onAction="#onDeleteUser"
                                                            wrapText="true"
                                                        visible="false"
                                                        managed="false"
                                                            styleClass="delete-action-button" />
                                                    <Button fx:id="submitUserButton"
                                                            text="%users.createUser"
                                                            onAction="#onSubmitUser"
                                                            wrapText="true"
                                                            styleClass="green-action-button" />
                                                </children>
                                            </HBox>

                                        </VBox>
                                    </content>
                                </ScrollPane>

            </children>
        </HBox>
    </center>
</BorderPane>
