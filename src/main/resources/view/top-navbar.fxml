<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<ScrollPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.vavateam1.controller.TopNavbarController"
            fitToHeight="true"
            fitToWidth="false"
            hbarPolicy="AS_NEEDED"
            vbarPolicy="NEVER"
            pannable="true"
            prefHeight="60.0"
            minHeight="60.0"
            maxHeight="60.0"
            styleClass="top-nav-scroll">
    <content>
        <HBox prefHeight="60.0"
              minHeight="60.0"
              maxHeight="60.0"
              styleClass="top-nav">

            <children>

                <Button fx:id="usersButton" text="%nav.users" styleClass="nav-tab" onAction="#onUsers" />
                <Button fx:id="menuButton" text="%nav.menu" styleClass="nav-tab" onAction="#onMenu" />
                <Button fx:id="financesButton" text="%nav.finances" styleClass="nav-tab" onAction="#onFinances" />
                <Button fx:id="inventoryButton" text="%nav.inventory" styleClass="nav-tab" onAction="#onInventory" />
                <Button fx:id="tableLayoutButton" text="%nav.tableLayout" styleClass="nav-tab" onAction="#onTableLayout" />

                <Region HBox.hgrow="ALWAYS" />
            </children>

            <padding>
                <Insets top="0.0" right="0.0" bottom="0.0" left="0.0"/>
            </padding>
        </HBox>
    </content>
</ScrollPane>
