<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
    fx:controller="dev.vavateam1.controller.KitchenController"
    spacing="18"
    styleClass="chef-board-root"
    style="-fx-padding: 20;">

    <Label text="%kitchen.board"
        styleClass="chef-board-title" />

    <ScrollPane fitToWidth="true"
        hbarPolicy="NEVER"
        VBox.vgrow="ALWAYS"
        styleClass="chef-board-scroll">
        <content>
            <HBox spacing="18"
                fillHeight="false"
                style="-fx-padding: 0 0 20 0;">
                <VBox fx:id="firstColumn"
                    spacing="18"
                    prefWidth="360"
                    HBox.hgrow="ALWAYS" />
                <VBox fx:id="secondColumn"
                    spacing="18"
                    prefWidth="360"
                    HBox.hgrow="ALWAYS" />
                <VBox fx:id="thirdColumn"
                    spacing="18"
                    prefWidth="360"
                    HBox.hgrow="ALWAYS" />
            </HBox>
        </content>
    </ScrollPane>

    <HBox alignment="CENTER_LEFT">
        <Button text="%nav.logout"
            onAction="#handleLogout"
            styleClass="chef-logout-button" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="languageButton"
            text="SK"
            onAction="#switchLanguage"
            styleClass="chef-logout-button" />
    </HBox>

</VBox>
