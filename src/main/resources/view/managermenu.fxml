<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="dev.vavateam1.controller.MenuController"
            maxWidth="Infinity"
            styleClass="page-root">

    <center>
                        <HBox spacing="20"
                              alignment="TOP_LEFT"
                              maxWidth="Infinity"
                              fillHeight="true"
                              styleClass="page-content">
                            <children>

                                <VBox fx:id="menuListPanel"
                                      spacing="0"
                                      minWidth="360"
                                      maxHeight="Infinity"
                                      HBox.hgrow="ALWAYS"
                                      styleClass="menu-outer-panel">
                                    <children>

                                                <ScrollPane fitToHeight="true"
                                                    fitToWidth="true"
                                                    hbarPolicy="AS_NEEDED"
                                                    vbarPolicy="NEVER"
                                                    prefHeight="60"
                                                    minHeight="60"
                                                    maxHeight="60"
                                                    pannable="true"
                                                    styleClass="menu-tabs-scroll">
                                            <content>
                                                <HBox fx:id="categoryTabsContainer"
                                                        spacing="0"
                                                        prefHeight="60"
                                                        minHeight="60"
                                                        maxHeight="60"
                                                        styleClass="menu-tabs-bar" />
                                            </content>
                                        </ScrollPane>

                                        <VBox spacing="18"
                                              maxHeight="Infinity"
                                              VBox.vgrow="ALWAYS"
                                              styleClass="menu-inner-panel">
                                            <children>

                                                <ScrollPane fitToWidth="true"
                                                            hbarPolicy="NEVER"
                                                            vbarPolicy="AS_NEEDED"
                                                            VBox.vgrow="ALWAYS"
                                                            styleClass="page-scroll">
                                                    <content>
                                                        <VBox fx:id="categorySectionsContainer"
                                                              spacing="18"
                                                              maxWidth="Infinity" />
                                                    </content>
                                                </ScrollPane>

                                                <HBox alignment="CENTER_RIGHT"
                                                      spacing="12">
                                                    <children>
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Button fx:id="editCategoryButton"
                                                                text="%menu.editCategory"
                                                                onAction="#onEditCategory"
                                                                wrapText="true"
                                                                styleClass="secondary-action-button" />
                                                        <Button fx:id="addMenuButton"
                                                                text="%menu.addItem"
                                                                onAction="#onAddMenu"
                                                            minHeight="46"
                                                            prefHeight="46"
                                                            maxHeight="46"
                                                                wrapText="true"
                                                                styleClass="green-action-button" />
                                                    </children>
                                                    <padding>
                                                        <Insets top="0" right="0" bottom="4" left="0" />
                                                    </padding>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <ScrollPane fx:id="menuFormPanel"
                                    fitToWidth="true"
                                    fitToHeight="true"
                                    hbarPolicy="NEVER"
                                    vbarPolicy="NEVER"
                                    pannable="false"
                                    prefWidth="360"
                                    minWidth="320"
                                    maxWidth="390"
                                    maxHeight="Infinity"
                                    visible="false"
                                    managed="false"
                                    styleClass="menu-form-panel">
                                    <content>
                                        <VBox spacing="18"
                                              fillWidth="true"
                                              styleClass="menu-form-content">

                                        <HBox alignment="CENTER_RIGHT">
                                            <children>
                                                <Button text="✕"
                                                        onAction="#onCloseForm"
                                                        styleClass="form-close-button" />
                                            </children>
                                        </HBox>

                                        <Label fx:id="menuFormTitle"
                                               text="%menu.addItem"
                                               wrapText="true"
                                               styleClass="menu-category-title" />

                                        <VBox spacing="8">
                                            <children>
                                                <Label text="%common.name" styleClass="form-label" />
                                                <TextField fx:id="nameField"
                                                           maxWidth="Infinity"
                                                           styleClass="form-input" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="8">
                                            <children>
                                                <Label text="%menu.description" styleClass="form-label" />
                                                <TextField fx:id="descriptionField"
                                                           maxWidth="Infinity"
                                                           styleClass="form-input" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="8">
                                            <children>
                                                <Label text="%menu.ingredients" styleClass="form-label" />
                                                <MenuButton fx:id="ingredientsButton"
                                                            text="%menu.selectIngredients"
                                                            maxWidth="Infinity"
                                                            styleClass="form-input" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="8">
                                            <children>
                                                <Label text="%common.category" styleClass="form-label" />
                                                <ComboBox fx:id="categoryField"
                                                          maxWidth="Infinity"
                                                          styleClass="form-input" />
                                            </children>
                                        </VBox>

                                        <CheckBox fx:id="isKitchenCheckBox"
                                                  text="%menu.isKitchen"
                                                  styleClass="form-checkbox" />

                                        <VBox spacing="8">
                                            <children>
                                                <Label text="%menu.pluCode" styleClass="form-label" />
                                                <TextField fx:id="pluCodeField"
                                                           promptText="%menu.pluCodeOptional"
                                                           maxWidth="Infinity"
                                                           styleClass="form-input" />
                                            </children>
                                        </VBox>

                                        <HBox spacing="20">
                                            <children>
                                                <VBox spacing="8" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="%menu.price" styleClass="form-label" />
                                                        <TextField fx:id="priceField"
                                                                   maxWidth="Infinity"
                                                                   styleClass="form-input" />
                                                    </children>
                                                </VBox>

                                                <VBox spacing="8" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="%common.discount" styleClass="form-label" />
                                                        <TextField fx:id="discountField"
                                                                   maxWidth="Infinity"
                                                                   styleClass="form-input" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <Region VBox.vgrow="ALWAYS" />

                                        <HBox alignment="CENTER_RIGHT" spacing="12">
                                            <children>
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Button fx:id="deleteMenuButton"
                                                        text="%common.delete"
                                                        visible="false"
                                                        managed="false"
                                                        wrapText="false"
                                                        onAction="#onDeleteMenu"
                                                    styleClass="delete-action-button" />
                                                <Button fx:id="submitMenuButton"
                                                        text="%menu.addMenu"
                                                        onAction="#onSubmitMenu"
                                                        wrapText="false"
                                                        styleClass="green-action-button" />
                                            </children>
                                        </HBox>

                                        </VBox>
                                    </content>
                                </ScrollPane>

                                <ScrollPane fx:id="categoryFormPanel"
                                    fitToWidth="true"
                                    fitToHeight="true"
                                    hbarPolicy="NEVER"
                                    vbarPolicy="NEVER"
                                    pannable="false"
                                    prefWidth="360"
                                    minWidth="320"
                                    maxWidth="390"
                                    maxHeight="Infinity"
                                    visible="false"
                                    managed="false"
                                    styleClass="menu-form-panel">
                                    <content>
                                        <VBox spacing="18"
                                              fillWidth="true"
                                              styleClass="menu-form-content">

                                        <HBox alignment="CENTER_RIGHT">
                                            <children>
                                                <Button text="✕"
                                                        onAction="#onCloseCategoryForm"
                                                        styleClass="form-close-button" />
                                            </children>
                                        </HBox>

                                        <Label fx:id="categoryFormTitle"
                                               text="%menu.addCategory"
                                               wrapText="true"
                                               styleClass="menu-category-title" />

                                        <VBox spacing="8">
                                            <children>
                                                <Label text="%menu.categoryName" styleClass="form-label" />
                                                <TextField fx:id="categoryNameField"
                                                           maxWidth="Infinity"
                                                           styleClass="form-input" />
                                            </children>
                                        </VBox>

                                        <Region VBox.vgrow="ALWAYS" />

                                        <HBox alignment="CENTER_RIGHT" spacing="12">
                                            <children>
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Button fx:id="deleteCategoryButton"
                                                        text="%common.delete"
                                                        visible="false"
                                                        managed="false"
                                                        wrapText="false"
                                                        onAction="#onDeleteCategory"
                                                    styleClass="delete-action-button" />
                                                <Button fx:id="submitCategoryButton"
                                                        text="%menu.addCategory"
                                                        onAction="#onSubmitCategory"
                                                        wrapText="false"
                                                        styleClass="green-action-button" />
                                            </children>
                                        </HBox>

                                        </VBox>
                                    </content>
                                </ScrollPane>

                            </children>
                        </HBox>
    </center>
</BorderPane>
