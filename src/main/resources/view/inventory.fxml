<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<StackPane  fx:id="rootStack"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="dev.vavateam1.controller.InventoryController">

        <VBox spacing="16"
              fx:id="root"
              style="
                -fx-padding: 20;
                -fx-background-color: -app-background;
                -fx-border-color: transparent;
              ">

            <children>
                <!-- Top Actions -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <children>
                        <Region HBox.hgrow="ALWAYS" />

                        <Button text="%common.import"
                                minWidth="100"
                                minHeight="40"
                                prefHeight="40"
                                maxHeight="40"
                                onAction="#onImportInventory"
                                maxWidth="Infinity"
                                styleClass="inv-action-btn"/>

                        <Button text="%common.export"
                                minWidth="100"
                                minHeight="40"
                                prefHeight="40"
                                maxHeight="40"
                                onAction="#onExportInventory"
                                maxWidth="Infinity"
                                styleClass="inv-action-btn"/>
                    </children>
                </HBox>

                <!-- Search Bar -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <children>
                        <TextField fx:id="searchField"
                                   promptText="%inventory.search"
                                   onAction="#onApplyFilter"
                                   prefWidth="300"
                                   style="-fx-background-color:-app-foreground; -fx-background-radius:24; -fx-border-radius:24; -fx-padding:10 16 10 16; -fx-font-size:14; -fx-text-fill:-app-text; -fx-prompt-text-fill:-app-text-muted;" />
                        <Button text="%common.filter"
                                onAction="#onToggleFilterPanel"
                                style="-fx-background-color:-app-foreground; -fx-text-fill:-app-text; -fx-background-radius:24; -fx-border-color:-app-blue-border; -fx-border-radius:24; -fx-padding:10 20 10 20; -fx-cursor:hand;" />
                    
                        <Region HBox.hgrow="ALWAYS" />

                        <Button fx:id="editButton"
                                text="%common.edit"
                                minWidth="100"
                                onAction="#toggleEditMode"
                                maxWidth="Infinity"
                            styleClass="secondary-action-button-small"/>
                    </children>
                </HBox>

                <!-- Filter Panel -->
                <VBox fx:id="filterPanel"
                      spacing="10"
                      visible="false"
                      managed="false"
                      style="-fx-background-color:-app-foreground; -fx-background-radius:16; -fx-padding:14 18 14 18;">
                    <children>
                        <HBox spacing="16" alignment="CENTER_LEFT">
                            <children>
                                <Label text="%common.status"
                                       style="-fx-font-size:13; -fx-text-fill:-app-text;" />

                                <Button fx:id="allItemsButton"
                                        text="%inventory.allItems"
                                        onAction="#onFilterAllItems"
                                        style="-fx-background-color:-app-blue-primary; -fx-text-fill:-app-foreground; -fx-background-radius:20; -fx-padding:8 20 8 20; -fx-cursor:hand; -fx-font-size:14;" />
                                <Button fx:id="lowStockButton"
                                        text="%inventory.lowStock"
                                        onAction="#onFilterLowStock"
                                        style="-fx-background-color:-app-blue-secondary; -fx-text-fill:-app-text; -fx-background-radius:20; -fx-padding:8 20 8 20; -fx-cursor:hand; -fx-font-size:14;" />
                                <Button fx:id="criticalButton"
                                        text="%inventory.critical"
                                        onAction="#onFilterCritical"
                                        style="-fx-background-color:-app-blue-secondary; -fx-text-fill:-app-text; -fx-background-radius:20; -fx-padding:8 20 8 20; -fx-cursor:hand; -fx-font-size:14;" />
                            </children>
                        </HBox>

                        <HBox spacing="16" alignment="CENTER_LEFT">
                            <children>
                                <Label text="%common.quantity"
                                       style="-fx-font-size:13; -fx-text-fill:-app-text;" />

                                <TextField fx:id="quantityFromField"
                                           promptText="%inventory.quantityFrom"
                                           prefWidth="140"
                                           style="-fx-background-radius:12; -fx-font-size:13;" />

                                <Label text="%finance.toLabel"
                                       style="-fx-font-size:13; -fx-text-fill:-app-text;" />

                                <TextField fx:id="quantityToField"
                                           promptText="%inventory.quantityTo"
                                           prefWidth="140"
                                           style="-fx-background-radius:12; -fx-font-size:13;" />

                                <Region HBox.hgrow="ALWAYS" />

                                <Button text="%common.apply"
                                        onAction="#onApplyFilter"
                                        style="-fx-background-color:-app-blue-border; -fx-text-fill:-app-foreground; -fx-background-radius:20; -fx-padding:8 20 8 20; -fx-cursor:hand; -fx-font-size:13;" />
                                <Button text="%common.clear"
                                        onAction="#onClearFilter"
                                        style="-fx-background-color:-app-background; -fx-text-fill:-app-text; -fx-background-radius:20; -fx-border-color:-app-border; -fx-border-radius:20; -fx-padding:8 20 8 20; -fx-cursor:hand; -fx-font-size:13;" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- Header Row -->
                <GridPane hgap="0"
                          style="-fx-background-color:-app-foreground; -fx-background-radius:16; -fx-border-radius:16; -fx-border-color:-app-blue-border; -fx-border-width:2; -fx-padding:12 16 12 16;">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="18" />
                        <ColumnConstraints percentWidth="22" />
                        <ColumnConstraints percentWidth="14" />
                        <ColumnConstraints percentWidth="18" />
                        <ColumnConstraints percentWidth="18" />
                    </columnConstraints>
                    <children>
                        <Label fx:id="itemIdHeaderLabel"
                               text="%inventory.itemId"
                               onMouseClicked="#onSortByItemId"
                               GridPane.columnIndex="0"
                               GridPane.halignment="CENTER"
                               style="-fx-font: bold 14px system; -fx-text-fill:-app-text; -fx-cursor:hand;" />
                        <Label fx:id="nameHeaderLabel"
                               text="%common.name"
                               onMouseClicked="#onSortByName"
                               GridPane.columnIndex="1"
                               GridPane.halignment="CENTER"
                               style="-fx-font: bold 14px system; -fx-text-fill:-app-text; -fx-cursor:hand;" />
                        <Label fx:id="quantityHeaderLabel"
                               text="%common.quantity"
                               onMouseClicked="#onSortByQuantity"
                               GridPane.columnIndex="2"
                               GridPane.halignment="CENTER"
                               style="-fx-font: bold 14px system; -fx-text-fill:-app-text; -fx-cursor:hand;" />
                        <Label fx:id="minimalQuantityHeaderLabel"
                               text="%inventory.minimalQuantity"
                               onMouseClicked="#onSortByMinimalQuantity"
                               GridPane.columnIndex="3"
                               GridPane.halignment="CENTER"
                               style="-fx-font: bold 14px system; -fx-text-fill:-app-text; -fx-cursor:hand;" />
                        <Label fx:id="statusHeaderLabel"
                               text="%common.status"
                               onMouseClicked="#onSortByStatus"
                               GridPane.columnIndex="4"
                               GridPane.halignment="CENTER"
                               style="-fx-font: bold 14px system; -fx-text-fill:-app-text; -fx-cursor:hand;" />
                    </children>
                </GridPane>

                <!-- Items Container -->
                <ScrollPane fitToWidth="true"
                            VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent;">
                    
                    <VBox fx:id="itemsContainer" spacing="10" />

                </ScrollPane>

                <Region VBox.vgrow="ALWAYS" />
            </children>

            <padding>
                <Insets top="0" right="0" bottom="0" left="0" />
            </padding>
        </VBox>

    <!-- Toast style popup -->
    <Label fx:id="toastLabel"
            text="%inventory.invalidCode"
            visible="false"
            StackPane.alignment="TOP_CENTER">

        <StackPane.margin>
            <Insets top="20"/>
        </StackPane.margin>

    </Label>

</StackPane>
