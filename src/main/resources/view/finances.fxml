<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="dev.vavateam1.controller.FinancesController"
            maxWidth="Infinity"
            styleClass="page-root">

    <center>
        <ScrollPane fitToWidth="true"
                    fitToHeight="true"
                    hbarPolicy="AS_NEEDED"
                    vbarPolicy="AS_NEEDED"
                    styleClass="page-scroll">
            <content>
                <VBox spacing="16"
                      maxWidth="Infinity"
                      style="-fx-padding:20; -fx-background-color:-app-background;">
                    <children>
                        <HBox spacing="14" alignment="CENTER_RIGHT">
                            <children>
                                <VBox prefWidth="240"
                                    prefHeight="72"
                                    alignment="CENTER_LEFT"
                                    style="-fx-background-color:-app-foreground; -fx-background-radius:16; -fx-padding:8 14 8 14;">
                                    <children>
                                        <Label text="%finance.totalSales"
                                            style="-fx-text-fill:-app-text; -fx-font-size:12px;" />
                                        <Label fx:id="dailySalesLabel"
                                            text="2453.65"
                                            style="-fx-text-fill:-app-text; -fx-font-size:28px; -fx-font-weight:bold;" />
                                    </children>
                                </VBox>

                                <VBox prefWidth="240"
                                    prefHeight="72"
                                    alignment="CENTER_LEFT"
                                    style="-fx-background-color:-app-foreground; -fx-background-radius:16; -fx-padding:8 14 8 14;">
                                    <children>
                                        <Label text="%finance.soldItems"
                                            style="-fx-text-fill:-app-text; -fx-font-size:12px;" />
                                        <Label fx:id="soldItemsTotalLabel"
                                            text="45"
                                            style="-fx-text-fill:-app-text; -fx-font-size:28px; -fx-font-weight:bold;" />
                                    </children>
                                </VBox>

                                <Region HBox.hgrow="ALWAYS" />

                                <Button text="%finance.exportReport"
                                        onAction="#onExportFinanceReport"
                                        style="-fx-background-color:-app-add; -fx-text-fill:-app-text; -fx-background-radius:24; -fx-padding:10 24 10 24; -fx-cursor:hand; -fx-font-size:14;" />
                            </children>
                        </HBox>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <children>
                                <TextField fx:id="searchField"
                                        promptText="%finance.search"
                                        onAction="#onApplyFilter"
                                        prefWidth="300"
                                        style="-fx-background-color:-app-foreground; -fx-background-radius:24; -fx-border-radius:24; -fx-padding:10 16 10 16; -fx-font-size:14; -fx-text-fill:-app-text; -fx-prompt-text-fill:-app-text-muted;" />
                                <Button text="%common.filter"
                                        onAction="#onToggleFilterPanel"
                                        style="-fx-background-color:-app-foreground; -fx-text-fill:-app-text; -fx-background-radius:24; -fx-border-color:-app-blue-border; -fx-border-radius:24; -fx-padding:10 20 10 20; -fx-cursor:hand;" />
                            </children>
                        </HBox>

                        <VBox fx:id="filterPanel"
                              spacing="10"
                              visible="false"
                              managed="false"
                              style="-fx-background-color:-app-foreground; -fx-background-radius:16; -fx-padding:14 18 14 18;">
                            <children>
                                <HBox spacing="16" alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="%finance.categoryLabel"
                                               style="-fx-font-size:13; -fx-text-fill:-app-text;" />
                                        <ComboBox fx:id="categoryCombo"
                                                  promptText="%finance.allCategories"
                                                  prefWidth="200"
                                                  style="-fx-background-radius:12; -fx-font-size:13;" />

                                        <Label text="%finance.soldFrom"
                                               style="-fx-font-size:13; -fx-text-fill:-app-text;" />
                                        <DatePicker fx:id="fromDatePicker"
                                                    promptText="%finance.fromDate"
                                                    prefWidth="160"
                                                    style="-fx-font-size:13;" />

                                        <Label text="%finance.toLabel"
                                               style="-fx-font-size:13; -fx-text-fill:-app-text;" />
                                        <DatePicker fx:id="toDatePicker"
                                                    promptText="%finance.toDate"
                                                    prefWidth="160"
                                                    style="-fx-font-size:13;" />

                                        <Region HBox.hgrow="ALWAYS" />

                                        <Button text="%common.apply"
                                                onAction="#onApplyFilter"
                                                style="-fx-background-color:-app-blue-border; -fx-text-fill:-app-foreground; -fx-background-radius:20; -fx-padding:8 20 8 20; -fx-cursor:hand; -fx-font-size:13;" />
                                        <Button text="%common.clear"
                                                onAction="#onClearFilter"
                                                style="-fx-background-color:-app-background; -fx-text-fill:-app-text; -fx-background-radius:20; -fx-border-color:-app-border; -fx-border-radius:20; -fx-padding:8 20 8 20; -fx-cursor:hand; -fx-font-size:13;" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <GridPane hgap="0"
                                style="-fx-background-color:-app-foreground; -fx-background-radius:16; -fx-border-radius:16; -fx-border-color:-app-blue-border; -fx-border-width:2; -fx-padding:12 16 12 16;">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="25" />
                                <ColumnConstraints percentWidth="25" />
                                <ColumnConstraints percentWidth="25" />
                                <ColumnConstraints percentWidth="25" />
                            </columnConstraints>
                            <children>
                                <Label fx:id="itemIdHeaderLabel"
                                    text="%finance.itemId"
                                    onMouseClicked="#onSortByItemId"
                                    GridPane.columnIndex="0"
                                    GridPane.halignment="CENTER"
                                    style="-fx-font-weight:bold; -fx-font-size:14px; -fx-text-fill:-app-text; -fx-cursor:hand;" />
                                <Label fx:id="itemNameHeaderLabel"
                                    text="%common.name"
                                    onMouseClicked="#onSortByName"
                                    GridPane.columnIndex="1"
                                    GridPane.halignment="CENTER"
                                    style="-fx-font-weight:bold; -fx-font-size:14px; -fx-text-fill:-app-text; -fx-cursor:hand;" />
                                <Label fx:id="soldPiecesHeaderLabel"
                                    text="%finance.soldPieces"
                                    onMouseClicked="#onSortBySoldPieces"
                                    GridPane.columnIndex="2"
                                    GridPane.halignment="CENTER"
                                    style="-fx-font-weight:bold; -fx-font-size:14px; -fx-text-fill:-app-text; -fx-cursor:hand;" />
                                <Label fx:id="pricePerPieceHeaderLabel"
                                    text="%finance.pricePerPiece"
                                    onMouseClicked="#onSortByPricePerPiece"
                                    GridPane.columnIndex="3"
                                    GridPane.halignment="CENTER"
                                    style="-fx-font-weight:bold; -fx-font-size:14px; -fx-text-fill:-app-text; -fx-cursor:hand;" />
                            </children>
                        </GridPane>

                        <VBox fx:id="itemsContainer" spacing="10" />

                        <Region VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
